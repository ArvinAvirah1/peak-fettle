# Peak Fettle App — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real keys.

# Backend API base URL
# Development:  http://localhost:4000
# Production:   https://api.peakfettle.com  (or your Supabase/Render URL)
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Supabase project URL (used by HealthKit sync and storage)
# Found in: Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon key (public — safe to include in the app bundle)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# PostHog analytics (optional — leave blank to disable)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
