# Peak Fettle Marketing Site — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" address for outbound emails. Must be a domain verified in Resend.
RESEND_FROM_EMAIL=Peak Fettle <noreply@peakfettle.com>

# Email address that receives internal waitlist signup notifications.
RESEND_WAITLIST_TO=founder@peakfettle.com
