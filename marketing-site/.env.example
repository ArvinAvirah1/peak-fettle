# Peak Fettle Marketing Site — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.

# ---- Public (exposed to the browser; safe, non-secret) ----

# Canonical site origin. Used for SEO canonicals, OG tags, sitemap, robots.
NEXT_PUBLIC_SITE_URL=https://peakfettle.com

# App store links. Leave blank until the app is live — the download buttons
# then point at the on-page "get notified" capture so nothing dead-ends.
NEXT_PUBLIC_IOS_URL=
NEXT_PUBLIC_ANDROID_URL=

# ---- Server-only (secret) ----

# Resend API key (https://resend.com/api-keys) — powers /api/waitlist.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" address for outbound emails. Must be a domain verified in Resend.
RESEND_FROM_EMAIL=Peak Fettle <noreply@peakfettle.com>

# Address that receives internal signup notifications.
RESEND_WAITLIST_TO=founder@peakfettle.com
