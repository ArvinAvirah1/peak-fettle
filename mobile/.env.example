# Copy this file to .env.local and fill in values for your environment.
# Expo exposes all EXPO_PUBLIC_* variables to the client bundle — do NOT
# put secrets in EXPO_PUBLIC_* vars. The API URL is safe to expose.

# Base URL for the Peak Fettle REST API.
# For local dev: http://localhost:3001
# For production: https://api.peakfettle.com (set once infra is provisioned)
EXPO_PUBLIC_API_URL=http://localhost:3001

# PowerSync instance URL — get this from your PowerSync dashboard after provisioning.
# Format: https://<your-instance-id>.powersync.journeyapps.com
EXPO_PUBLIC_POWERSYNC_URL=https://YOUR_INSTANCE.powersync.journeyapps.com
