{
  "expo": {
    "name": "Peak Fettle",
    "slug": "peak-fettle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.peakfettle.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#13415C"
      },
      "package": "com.peakfettle.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "react-native-health",
        {
          "NSHealthShareUsageDescription": "Peak Fettle reads resting heart rate, HRV, sleep, and active energy data to personalise your training plans.",
          "NSHealthUpdateUsageDescription": "Peak Fettle does not write health data."
        }
      ]
    ],
    "scheme": "peak-fettle",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de9093c0-e047-43cd-a1de-16334f5a059b"
      }
    }
  }
}
