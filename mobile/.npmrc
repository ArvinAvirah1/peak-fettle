# EAS Build runs `npm ci --include=dev` which is strict about peer deps.
# Several deps (e.g. @shopify/react-native-skia 1.x via victory-native) declare
# peer React <19, but Expo SDK 54 ships React 19. Without this flag npm ci
# aborts with ERESOLVE and the build fails before any code runs.
# Matches what `npm install --legacy-peer-deps` does locally.
legacy-peer-deps=true
